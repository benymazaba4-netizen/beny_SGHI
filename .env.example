# SGHI ERP Médical — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs

# Django
# DEBUG=False par défaut sans fichier .env — mettre DEBUG=True en développement local
DEBUG=True
# Obligatoire en production (DEBUG=False) — générer une clé aléatoire de 50+ caractères
SECRET_KEY=changez-moi-en-production-32-caracteres-min
ALLOWED_HOSTS=localhost,127.0.0.1

# Django /admin/ — DÉSACTIVÉ par défaut (sécurité). Ne pas activer en production.
DJANGO_ADMIN_ENABLED=False

# Base de données
# ── Option A : PostgreSQL (recommandé — docker compose up -d db)
#    Setup auto : .\scripts\setup-postgres.ps1
DB_ENGINE=postgresql
DB_NAME=sghi_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
# DB_CONN_MAX_AGE=60
# DB_CONNECT_TIMEOUT=10

# ── Option B : SQLite (dev minimal, sans Docker)
# DB_ENGINE=sqlite

# Redis (cache KPIs, rate limiting)
# REDIS_URL=redis://127.0.0.1:6379/1

# Chiffrement données sensibles (32+ caractères recommandés)
# FIELD_ENCRYPTION_KEY=votre-cle-aes-256-secrete

# JWT
JWT_EXPIRATION_HOURS=1
REFRESH_TOKEN_DAYS=30

# CORS (frontend Vue.js)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# HTTPS (production / Render)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# CSRF_TRUSTED_ORIGINS=https://sghi-api.onrender.com,https://sghi-patient.onrender.com

# Render : DATABASE_URL est injecté automatiquement depuis PostgreSQL
# DATABASE_URL=postgres://user:pass@host:5432/sghi_db

# Email SMTP
# ╔════════════════════════════════════════════════════════════════╗
# ║  CONFIGURATION EMAIL - 3 OPTIONS                              ║
# ╚════════════════════════════════════════════════════════════════╝

# OPTION 1 : DEV LOCAL (Mailpit - Console Email)
# ─────────────────────────────────────────────
# Démarrer Mailpit :
#   Windows : .\scripts\start-mailpit.ps1
#   Linux   : docker run -p 1025:1025 -p 8025:8025 axllent/mailpit
# Web UI : http://127.0.0.1:8025
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=127.0.0.1
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=30
DEFAULT_FROM_EMAIL=SGHI <noreply@sghi.local>
EMAIL_USE_REAL_SMTP=False

# OPTION 2 : PRODUCTION - GMAIL (RECOMMANDÉ)
# ──────────────────────────────────────────
# ⚠️  IMPORTANT : Suivre les étapes du docs/MAILING_SETUP.md
# 
# 1. Activer 2FA sur Google Account
# 2. Générer "App Password" : myaccount.google.com > Security > App passwords
# 3. Copier le mot de passe (format : xxxx xxxx xxxx xxxx - 16 caractères)
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=votre@gmail.com
# EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
# EMAIL_TIMEOUT=30
# DEFAULT_FROM_EMAIL=SGHI <votre@gmail.com>
# EMAIL_USE_REAL_SMTP=True

# OPTION 3 : BREVO (recommandé sur Render Free — HTTPS, pas de SMTP)
# ──────────────────────────────────────────────────────────────────
# 1. Compte https://app.brevo.com
# 2. Settings → SMTP & API → API Keys → Create a new API key
# 3. Senders → ajouter/vérifier benymazaba4@gmail.com
# BREVO_API_KEY=xkeysib-xxxxxxxx
# BREVO_SENDER_EMAIL=benymazaba4@gmail.com
# BREVO_SENDER_NAME=SGHI ERP
# OTP_ALLOW_BYPASS=False

# OPTION 4 : CONSOLE UNIQUEMENT (Logs, pas d'envoi réel)
# ─────────────────────────────────────────────────────
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# OTP PAR EMAIL - Connexion Sécurisée
# ────────────────────────────────────
# Envoyé dynamiquement à user.email (Gmail, Yahoo, Outlook, pro…)
EMAIL_OTP_ENABLED=True
OTP_EXPIRY_SECONDS=600  # 10 minutes
OTP_MAX_RESENDS=3       # Renvois max par session OTP
# Code de secours (DEBUG=True ou OTP_ALLOW_BYPASS=True)
OTP_DEV_BYPASS_CODE=123456
OTP_ALLOW_BYPASS=False

# Verrouillage de compte (force brute)
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
PATIENT_QR_TTL_SECONDS=300

# RAPPELS RDV - Tâche Planifiée
# ──────────────────────────────
# Planifier l'envoi automatique de rappels 24h avant les RDV confirmés.
# Commande : python manage.py send_rdv_reminders
# Cron Windows : .\scripts\schedule-rdv-reminders.ps1
RDV_REMINDER_HOURS=24
RDV_REMINDER_WINDOW_HOURS=1

# Push FCM (notifications mobile Android/iOS)
# Cle serveur Firebase Console > Cloud Messaging > Legacy server key
# FCM_SERVER_KEY=

